# ============================================================
# MAPI Customer Portal — environment variables
# Copy to .env.local for development; set in Vercel for prod.
# None of these are required for the demo to run — every value
# has a safe fallback — but ALL should be set in real production.
# ============================================================

# --- Site ---------------------------------------------------
# Canonical origin (used by sitemap.xml / robots.txt)
NEXT_PUBLIC_SITE_URL=https://mapi-customer-portal-poc.vercel.app

# --- CMS authentication (server-side, /api/cms/*) ------------
# SHA-256 hex of the manager email (lowercased) and password.
# Generate:  node -e "console.log(require('crypto').createHash('sha256').update('VALUE').digest('hex'))"
CMS_EMAIL_HASH=
CMS_PASSWORD_HASH=
# Random secret for HMAC-signing the session cookie (32+ bytes).
# Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CMS_SESSION_SECRET=
# Display name/role stamped into the session (optional)
CMS_MANAGER_NAME=
CMS_MANAGER_ROLE=

# --- Analytics (spec 4.15 / 13.23) ---------------------------
# GA4 measurement id, e.g. G-XXXXXXXXXX. Empty = analytics off.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- PostgreSQL (the professional portal database) -----------
# Any standard Postgres connection string activates the layer:
# Vercel Postgres / Neon / Supabase / self-hosted. Tables (leads,
# orders) are created automatically on first write.
# Vercel: Dashboard → Storage → Create Database → Postgres (Neon)
#         → Connect to project → DATABASE_URL is injected.
DATABASE_URL=

# --- Google Workspace integration ----------------------------
# All optional. Unset = pure demo mode (localStorage only).
#
# (1) Lead database — Google Sheets:
#     Create a service account in Google Cloud Console (IAM → Service
#     Accounts), enable the "Google Sheets API", create a JSON key, and
#     SHARE the target spreadsheet with the service-account email
#     (editor). Key can be pasted as raw PEM or base64 of the PEM.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=
# The spreadsheet id from its URL (docs.google.com/spreadsheets/d/<ID>)
GOOGLE_SHEETS_ID=
#
# (2) New-lead notifications — Google Chat:
#     In the sales team's Chat space: ⚙ → Apps & integrations →
#     Webhooks → Add. Paste the webhook URL here.
GOOGLE_CHAT_WEBHOOK_URL=
#
# (3) CMS sign-in with Google Workspace:
#     Google Cloud Console → APIs & Services → Credentials →
#     OAuth client ID (Web). Authorized JS origins: the portal URL.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Comma-separated Google accounts allowed into /cms
CMS_ALLOWED_GOOGLE_EMAILS=mapicomportal@gmail.com

# --- E2E (never set in Vercel — CI/local only) ---------------
# Playwright uses these to run the full CMS journey test.
CMS_E2E_EMAIL=
CMS_E2E_PASSWORD=
