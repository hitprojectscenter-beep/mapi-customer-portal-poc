# ============================================================
# MAPI Customer Portal — environment variables
# Copy to .env.local for development; set in Vercel for prod.
# None of these are required for the demo to run — every value
# has a safe fallback — but ALL should be set in real production.
# ============================================================

# --- Site ---------------------------------------------------
# Canonical origin (used by sitemap.xml / robots.txt)
NEXT_PUBLIC_SITE_URL=https://mapi-customer-portal-poc.vercel.app

# --- CMS authentication (server-side, /api/cms/*) ------------
# SHA-256 hex of the manager email (lowercased) and password.
# Generate:  node -e "console.log(require('crypto').createHash('sha256').update('VALUE').digest('hex'))"
CMS_EMAIL_HASH=
CMS_PASSWORD_HASH=
# Random secret for HMAC-signing the session cookie (32+ bytes).
# Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CMS_SESSION_SECRET=
# Display name/role stamped into the session (optional)
CMS_MANAGER_NAME=
CMS_MANAGER_ROLE=

# --- Analytics (spec 4.15 / 13.23) ---------------------------
# GA4 measurement id, e.g. G-XXXXXXXXXX. Empty = analytics off.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- E2E (never set in Vercel — CI/local only) ---------------
# Playwright uses these to run the full CMS journey test.
CMS_E2E_EMAIL=
CMS_E2E_PASSWORD=
